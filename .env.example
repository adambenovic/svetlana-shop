# Copy to .env (local) or .env.tunnel (deploy) and fill in real values.
# NEXT_PUBLIC_* are inlined at build time — pass them as Docker build args in prod.

# ── Core ────────────────────────────────────────────────────────────
DATABASE_URI=postgresql://svetlana:svetlana@localhost:5432/svetlana
PAYLOAD_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Operator token gating the seed/backfill endpoints (Bearer auth)
INVOICE_BACKFILL_TOKEN=change-me-to-a-random-token

# ── GoPay ───────────────────────────────────────────────────────────
# GOPAY_ENV=prod uses GOPAY_*, GOPAY_ENV=test uses GOPAY_TEST_* (sandbox)
GOPAY_ENV=test
GOPAY_API_URL=https://gate.gopay.cz/api
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=
GOPAY_GO_ID=
GOPAY_TEST_API_URL=https://gw.sandbox.gopay.com/api
GOPAY_TEST_CLIENT_ID=
GOPAY_TEST_CLIENT_SECRET=
GOPAY_TEST_GO_ID=

# ── Packeta ─────────────────────────────────────────────────────────
PACKETA_API_KEY=
NEXT_PUBLIC_PACKETA_WIDGET_KEY=

# ── Email (Brevo) ───────────────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=shop@svetlanalampe.sk

# ── Postgres (used by docker-compose) ───────────────────────────────
POSTGRES_DB=svetlana
POSTGRES_USER=svetlana
POSTGRES_PASSWORD=svetlana
